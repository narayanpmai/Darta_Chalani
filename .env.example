# LGOMS — Environment Variables Template
# Copy this file to .env and fill in the values
# Production deployment मा यी values राख्नुहोस्

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DB_HOST=db
DB_NAME=lgoms_db
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Minimum 32 characters — production मा strong secret राख्नुहोस्
JWT_SECRET=your_very_strong_jwt_secret_here_minimum_32_chars
JWT_ISSUER=LGOMS_Api
JWT_AUDIENCE=LGOMS_Client
JWT_EXPIRY_MINUTES=480

# ─── AI Integration (Optional) ────────────────────────────────────────────────
# AI features को लागि OpenAI API key (छोड्न पनि हुन्छ)
AI_OPENAI_API_KEY=sk-your-openai-key-here
AI_OPENAI_MODEL=gpt-4o-mini
AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
